# Copy this file to .env.deployment and fill in values for the target Azure environment.
# Do not commit .env.deployment.

# Azure context
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=rg-foundry-pptx-agent
AZURE_LOCATION=eastus2

# Azure resource names
# ACR names must be globally unique, lowercase, alphanumeric, and 5-50 characters.
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT=cae-foundry-pptx-agent
AZURE_LOG_ANALYTICS_WORKSPACE=law-foundry-pptx-agent
AZURE_MANAGED_IDENTITY_NAME=id-foundry-pptx-agent
AZURE_CONTAINER_APP_NAME=ca-foundry-pptx-agent

# Container image
IMAGE_NAME=foundry-pptx-agent
IMAGE_TAG=latest

# Container App sizing
CONTAINERAPP_MIN_REPLICAS=1
CONTAINERAPP_MAX_REPLICAS=3
CONTAINERAPP_CPU=0.5
CONTAINERAPP_MEMORY=1.0Gi

# Application runtime
TEMPLATES_DIR=templates
OUTPUT_DIR=generated
DEFAULT_TEMPLATE_ID=sample-board-template
# Leave empty before the first deployment. Set to https://<container-app-fqdn> after deployment.
PUBLIC_BASE_URL=

# Microsoft Foundry target
FOUNDRY_AI_SERVICES_RESOURCE=
FOUNDRY_PROJECT_NAME=
# Example: https://<ai-services-resource>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=

# Filled in after deployment
SERVICE_URL=
OPENAPI_URL=
