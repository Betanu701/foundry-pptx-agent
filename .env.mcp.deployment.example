# Copy this file to .env.mcp.deployment and fill in values for an MCP deployment.
# Do not commit .env.mcp.deployment.

# Azure context
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=rg-foundry-pptx-agent-mcp
AZURE_LOCATION=eastus2

# Azure resource names
# ACR names must be globally unique, lowercase, alphanumeric, and 5-50 characters.
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT=cae-foundry-pptx-agent-mcp
AZURE_LOG_ANALYTICS_WORKSPACE=law-foundry-pptx-agent-mcp
AZURE_MANAGED_IDENTITY_NAME=id-foundry-pptx-agent-mcp
AZURE_CONTAINER_APP_NAME=ca-foundry-pptx-agent-mcp

# Container image
IMAGE_NAME=foundry-pptx-agent-mcp
IMAGE_TAG=latest
DOCKERFILE_PATH=Dockerfile.mcp

# MCP runtime
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8089

# Container App sizing
CONTAINERAPP_MIN_REPLICAS=1
CONTAINERAPP_MAX_REPLICAS=3
CONTAINERAPP_CPU=0.5
CONTAINERAPP_MEMORY=1.0Gi

# Application runtime
TEMPLATES_DIR=templates
OUTPUT_DIR=generated
DEFAULT_TEMPLATE_ID=sample-board-template
# Optional. If set, generated artifact URLs are absolute HTTP URLs from the companion API service.
# If this MCP server runs without the OpenAPI/API service, generated results still include artifact_path.
PUBLIC_BASE_URL=

# Microsoft Foundry target
FOUNDRY_AI_SERVICES_RESOURCE=
FOUNDRY_PROJECT_NAME=
# Example: https://<ai-services-resource>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=

# Filled in after deployment
MCP_SERVER_URL=
